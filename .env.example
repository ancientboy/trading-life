# 复制为 .env 后按需填写（模拟盘可不填 Binance 密钥，公开行情接口仍可用）

# Binance API（模拟盘可选）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Redis（本地开发默认 DB1，与生产隔离）
REDIS_URL=redis://localhost:6379/1

# 智谱 GLM（AI 分析 / Dashboard 对话）
ZHIPU_API_KEY=

# Telegram（通知，可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard
DASHBOARD_PORT=9095
TRADING_AGENT_ROOT=/workspace

# OpenClaw 集成（可选）
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=
OPENCLAW_SESSION=main
